# ── Authentication ───────────────────────────────────────────────────────
PRIVATE_KEY=your_private_key_here
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_API_SECRET=your_api_secret_here
POLYMARKET_API_PASSPHRASE=your_api_passphrase_here
PROXY_WALLET=your_proxy_wallet_address_here
EOA_ADDRESS=your_eoa_wallet_address_here

# ── Relayer / Builder API (from polymarket.com/settings?tab=builder) ─────
POLYMARKET_RELAYER_URL=https://relayer-v2.polymarket.com
POLYMARKET_BUILDER_API_KEY=your_builder_api_key_here
POLYMARKET_BUILDER_SECRET=your_builder_secret_here
POLYMARKET_BUILDER_PASSPHRASE=your_builder_passphrase_here

# ── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=polymarket
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=polymarket_tracker

# ── Betting ──────────────────────────────────────────────────────────────
BET_SIZE_USD=1.5
DAILY_LOSS_LIMIT=30.0
LOOP_INTERVAL=5

# ── Strategy toggles ────────────────────────────────────────────────────
STRATEGY_FARMING_ENABLED=true
STRATEGY_CALIBRATION_ENABLED=false
STRATEGY_MOMENTUM_ENABLED=true
STRATEGY_STREAK_ENABLED=false

# ── Farming parameters ──────────────────────────────────────────────────
FARMING_TRIGGER_POINT=0.65
FARMING_EXIT_POINT=0.30
FARMING_TRIGGER_MINUTES=1

# ── Momentum parameters ─────────────────────────────────────────────────
MOMENTUM_MIN_THRESHOLD=0.02
MOMENTUM_USE_STOP_LOSS=false
MOMENTUM_EXIT_POINT=0.40

# ── Streak parameters ───────────────────────────────────────────────────
STREAK_LENGTH=3
STREAK_DIRECTION=both

# ── Calibration parameters ──────────────────────────────────────────────
CALIBRATION_MAX_ENTRY_SECONDS=60
CALIBRATION_ENTRY_LOW=0.50
CALIBRATION_ENTRY_HIGH=0.60
CALIBRATION_MIN_DEVIATION=0.05

# ── Proxy (optional): socks5://127.0.0.1:9050 or socks5://user:pass@host:port
PROXY_URL=
